---
import { AvButton, AvCard, AvContainer, AvDrawer, AvEmptyState } from "@ansiversa/components";
import { server } from "../../actions";
import AppShell from "../../layouts/AppShell.astro";
import type { CarPoolGroup } from "../../modules/app/carPoolStore";

let groups: CarPoolGroup[] = [];
let loadError: string | null = null;

try {
  const result = await Astro.callAction(server.loadUserGroups, {});
  groups = (result?.data?.groups as any) || [];
} catch (error) {
  console.error("Error loading user groups:", error);
  loadError = error instanceof Error ? error.message : String(error);
}

const initialState = {
  groups,
  loadError,
};
---

<AppShell title="Car Pool – App" description="Manage shared commute groups inside the Ansiversa workspace.">
  <section class="av-section">
    <AvContainer>
      <div
        class="av-auth-stack-lg"
        x-data="$store.carPoolApp"
        x-init="initializeIndex($el.dataset.initial)"
        data-initial={JSON.stringify(initialState)}
      >
        <AvCard className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div class="av-auth-stack-xs">
              <p class="av-kicker">Car Pool</p>
              <h1 class="av-section-title">Shared commute groups</h1>
              <p class="av-text-soft">Create a group, invite members, and manage fair trip rotation from one protected workspace.</p>
            </div>
            <div class="av-row-wrap">
              <AvButton type="button" @click="openCreateGroupDrawer()">Create group</AvButton>
            </div>
          </div>

          <template x-if="error">
            <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
          </template>
        </AvCard>

        <AvCard variant="soft" className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div>
              <p class="av-kicker">Workspace</p>
              <h2 class="av-card-heading">Your groups</h2>
              <p class="av-text-soft">Each card opens the full group workspace with overview, members, trips, and fairness.</p>
            </div>
            <p class="av-text-soft"><span x-text="groups.length"></span> total</p>
          </div>

          <template x-if="!isLoading && groups.length === 0">
            <div class="av-auth-stack-sm">
              <AvEmptyState
                headline="No car pool groups yet"
                description="Create your first group to start organizing drivers, riders, and trip history."
              />
              <div class="av-row-wrap">
                <AvButton type="button" @click="openCreateGroupDrawer()">Create group</AvButton>
              </div>
            </div>
          </template>

          <template x-if="!isLoading && groups.length > 0">
            <div class="app-group-grid">
              <template x-for="group in groups" :key="group.id">
                <AvCard variant="soft" className="av-card--fullheight">
                  <div class="av-auth-stack-md">
                    <div class="av-row-between app-row-top">
                      <div class="av-auth-stack-xxs">
                        <h3 class="av-card-heading app-group-title" x-text="group.name"></h3>
                        <p class="av-text-soft">
                          Created <span x-text="formatDate(group.createdAt)"></span>
                        </p>
                      </div>
                      <span
                        class="av-badge"
                        :class="group.isArchived ? 'av-badge-danger' : 'av-badge-soft'"
                        x-text="group.isArchived ? 'Archived' : 'Active'"
                      ></span>
                    </div>

                    <div class="app-signal-grid">
                      <div class="app-signal">
                        <span class="app-signal__label">Working days</span>
                        <strong x-text="Array.isArray(group.workingDays) ? group.workingDays.length : 0"></strong>
                      </div>
                      <div class="app-signal">
                        <span class="app-signal__label">Workspace</span>
                        <strong x-text="group.isArchived ? 'Locked' : 'Ready'"></strong>
                      </div>
                    </div>

                    <div class="av-row-wrap">
                      <AvButton
                        type="button"
                        size="sm"
                        @click="navigateToGroup(group.id)"
                        :disabled="group.isArchived"
                      >
                        Open workspace
                      </AvButton>
                    </div>
                  </div>
                </AvCard>
              </template>
            </div>
          </template>

          <template x-if="isLoading">
            <p class="av-text-soft">Loading groups…</p>
          </template>
        </AvCard>

        <template x-if="showCreateGroupDrawer">
          <div
            class="av-drawer-overlay"
            @click.self="closeCreateGroupDrawer()"
            @keydown.escape.window="closeCreateGroupDrawer()"
            @close-drawer="closeCreateGroupDrawer()"
            x-cloak
          >
            <AvDrawer title="Create car pool group" description="Start a workspace for one commute team.">
              <form id="create-group-form" class="av-auth-stack-md" @submit.prevent="submitCreateGroup()">
                <label class="app-field">
                  <span class="app-label">Group name</span>
                  <input
                    type="text"
                    x-model="createGroupForm.name"
                    class="app-input"
                    placeholder="e.g. Office Team Alpha"
                    required
                  />
                </label>

                <div class="app-field">
                  <span class="app-label">Working days</span>
                  <div class="app-day-grid">
                    <template x-for="day in [
                      { value: 1, label: 'Mon' },
                      { value: 2, label: 'Tue' },
                      { value: 3, label: 'Wed' },
                      { value: 4, label: 'Thu' },
                      { value: 5, label: 'Fri' },
                      { value: 6, label: 'Sat' },
                      { value: 0, label: 'Sun' }
                    ]" :key="day.value">
                      <label class="app-day-chip">
                        <input
                          type="checkbox"
                          :value="day.value"
                          x-model="createGroupForm.workingDays"
                        />
                        <span x-text="day.label"></span>
                      </label>
                    </template>
                  </div>
                </div>
              </form>

              <Fragment slot="footer">
                <div class="av-auth-stack-xs av-w-full">
                  <template x-if="error">
                    <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
                  </template>
                  <div class="av-row-wrap av-drawer-footer-actions">
                    <AvButton variant="ghost" type="button" @click="closeCreateGroupDrawer()">Cancel</AvButton>
                    <AvButton type="submit" form="create-group-form" :disabled="isLoading">
                      <span x-text="isLoading ? 'Creating…' : 'Create group'"></span>
                    </AvButton>
                  </div>
                </div>
              </Fragment>
            </AvDrawer>
          </div>
        </template>
      </div>
    </AvContainer>
  </section>
</AppShell>
