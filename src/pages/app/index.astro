---
import AppShell from "../../layouts/AppShell.astro";
import { server } from "../../actions";

// Load initial data server-side
let groups = { groups: [] };
let selectedGroup = null;
let groupDetail = null;
let tripHistory = null;
let loadError = null;

try {
  const result = await server.loadUserGroups();
  groups = result || { groups: [] };
  selectedGroup = groups.groups && groups.groups.length > 0 ? groups.groups[0] : null;

  if (selectedGroup) {
    try {
      groupDetail = await server.loadGroupDetail({ groupId: selectedGroup.id });
      tripHistory = await server.listTripHistory({ groupId: selectedGroup.id, limit: 10 });
    } catch (e) {
      console.error("Error loading group detail:", e);
    }
  }
} catch (e) {
  console.error("Error loading user groups:", e);
  loadError = e instanceof Error ? e.message : String(e);
}

// Helper to format date
function formatDate(date: Date | string): string {
  const d = new Date(date);
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<AppShell>
  <div class="min-h-screen bg-gradient-to-br from-slate-50 to-slate-100">
    <div class="container max-w-4xl mx-auto px-4 py-8 md:py-12">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-slate-900">Car Pool</h1>
        <p class="text-lg text-slate-600 mt-2">Shared group rotation management</p>
      </div>

      <!-- Error Alert -->
      {loadError && (
        <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4">
          <h3 class="text-red-900 font-semibold mb-1">Error Loading Groups</h3>
          <p class="text-red-800 text-sm">{loadError}</p>
          <p class="text-red-700 text-xs mt-2">Please try refreshing or contacting support if the issue persists.</p>
        </div>
      )}

      <!-- Main Container with Alpine Store -->
      <div
        x-data="Object.assign($store.carPoolApp, {
          init() {
            this.groupIdFromServer = '{selectedGroup?.id || ''}';
            if (this.groupIdFromServer) {
              this.selectedGroupId = this.groupIdFromServer;
              this.loadGroupDetail();
            } else {
              this.loadUserGroups();
            }
          }
        })"
        x-effect="init()"
        class="space-y-6"
      >
        <!-- No Groups State -->
        <template x-if="groups.length === 0 && !isLoading">
          <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 text-center">
            <div class="text-6xl mb-4">🚗</div>
            <h2 class="text-2xl font-bold text-slate-900 mb-2">No Car Pools Yet</h2>
            <p class="text-slate-600 mb-6">Create your first car pool group to get started</p>
            <button
              @click="openCreateGroupDrawer()"
              class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-6 rounded-lg transition"
            >
              Create Group
            </button>
          </div>
        </template>

        <!-- Groups Exist -->
        <template x-if="groups.length > 0">
          <div class="space-y-6">
            <!-- Group Selector & Actions -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-slate-900">Groups</h2>
                <button
                  @click="openCreateGroupDrawer()"
                  class="text-sm bg-blue-600 hover:bg-blue-700 text-white font-semibold py-1 px-4 rounded-lg transition"
                >
                  + New Group
                </button>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <template x-for="group in groups" :key="group.id">
                  <button
                    @click="selectGroup(group.id)"
                    :class="selectedGroupId === group.id ? 'bg-blue-100 border-blue-300 text-blue-900' : 'bg-slate-50 border-slate-200 text-slate-700 hover:bg-slate-100'"
                    class="p-3 rounded-lg border-2 transition text-left"
                  >
                    <div class="font-semibold" x-text="group.name"></div>
                    <div class="text-sm opacity-70" x-text="group.rotationType.replace('_', ' ')"></div>
                  </button>
                </template>
              </div>
            </div>

            <!-- Tab Navigation -->
            <div class="bg-white rounded-xl shadow-sm border border-slate-200">
              <div class="flex border-b border-slate-200 overflow-x-auto">
                <button
                  @click="setSelectedTab('overview')"
                  :class="selectedTab === 'overview' ? 'border-b-2 border-blue-600 text-blue-600' : 'text-slate-600 hover:text-slate-900'"
                  class="flex-1 md:flex-auto px-4 md:px-6 py-4 font-semibold transition text-sm md:text-base"
                >
                  Overview
                </button>
                <button
                  @click="setSelectedTab('members')"
                  :class="selectedTab === 'members' ? 'border-b-2 border-blue-600 text-blue-600' : 'text-slate-600 hover:text-slate-900'"
                  class="flex-1 md:flex-auto px-4 md:px-6 py-4 font-semibold transition text-sm md:text-base"
                >
                  Members
                </button>
                <button
                  @click="setSelectedTab('schedule')"
                  :class="selectedTab === 'schedule' ? 'border-b-2 border-blue-600 text-blue-600' : 'text-slate-600 hover:text-slate-900'"
                  class="flex-1 md:flex-auto px-4 md:px-6 py-4 font-semibold transition text-sm md:text-base"
                >
                  Schedule
                </button>
                <button
                  @click="setSelectedTab('trips')"
                  :class="selectedTab === 'trips' ? 'border-b-2 border-blue-600 text-blue-600' : 'text-slate-600 hover:text-slate-900'"
                  class="flex-1 md:flex-auto px-4 md:px-6 py-4 font-semibold transition text-sm md:text-base"
                >
                  Trips
                </button>
              </div>

              <!-- Tab Content -->
              <div class="p-6 md:p-8 space-y-6">
                <!-- Overview Tab -->
                <div x-show="selectedTab === 'overview'" class="space-y-6">
                  <template x-if="selectedGroupDetail.group">
                    <div class="space-y-4">
                      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-gradient-to-br from-slate-50 to-slate-100 p-4 rounded-lg border border-slate-200">
                          <div class="text-sm text-slate-600 font-semibold mb-1">GROUP</div>
                          <div class="text-2xl font-bold text-slate-900" x-text="selectedGroupDetail.group.name"></div>
                        </div>
                        <div class="bg-gradient-to-br from-slate-50 to-slate-100 p-4 rounded-lg border border-slate-200">
                          <div class="text-sm text-slate-600 font-semibold mb-1">ROTATION TYPE</div>
                          <div class="text-2xl font-bold text-slate-900" x-text="selectedGroupDetail.group.rotationType.replace('_', ' ').toUpperCase().split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')"></div>
                        </div>
                        <div class="bg-gradient-to-br from-slate-50 to-slate-100 p-4 rounded-lg border border-slate-200">
                          <div class="text-sm text-slate-600 font-semibold mb-1">MEMBERS</div>
                          <div class="text-2xl font-bold text-slate-900" x-text="selectedGroupDetail.members.filter(m => m.isActive).length"></div>
                        </div>
                        <div class="bg-gradient-to-br from-slate-50 to-slate-100 p-4 rounded-lg border border-slate-200">
                          <div class="text-sm text-slate-600 font-semibold mb-1">START DATE</div>
                          <div class="text-sm font-bold text-slate-900" x-text="new Date(selectedGroupDetail.group.startDate).toLocaleDateString('en-US', {year: 'numeric', month: 'short', day: 'numeric'})"></div>
                        </div>
                      </div>

                      <div class="bg-blue-50 border-2 border-blue-200 rounded-lg p-6">
                        <div class="text-sm text-blue-600 font-semibold mb-2">TODAY'S DRIVER</div>
                        <div class="text-3xl font-bold text-blue-900" x-text="todaysSuggestedDriver ? 'User ' + todaysSuggestedDriver : 'Loading...'"></div>
                        <button
                          @click="openCreateTripDrawer()"
                          class="mt-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition"
                        >
                          + Add Trip
                        </button>
                      </div>
                    </div>
                  </template>
                </div>

                <!-- Members Tab -->
                <div x-show="selectedTab === 'members'" class="space-y-4">
                  <template x-if="selectedGroupDetail.members.filter(m => m.isActive).length > 0">
                    <div class="space-y-3">
                      <template x-for="(member, index) in selectedGroupDetail.members.filter(m => m.isActive)" :key="member.id">
                        <div class="flex items-center justify-between bg-slate-50 p-4 rounded-lg border border-slate-200">
                          <div class="flex items-center space-x-4">
                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center text-white font-bold" x-text="index + 1"></div>
                            <div>
                              <div class="font-semibold text-slate-900" x-text="member.userId"></div>
                              <div class="text-sm text-slate-600">Order: <span x-text="member.sortOrder + 1"></span></div>
                            </div>
                          </div>
                        </div>
                      </template>
                    </div>
                  </template>

                  <button
                    @click="openAddMembersDrawer()"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition"
                  >
                    + Add Members
                  </button>
                </div>

                <!-- Schedule Tab -->
                <div x-show="selectedTab === 'schedule'" class="space-y-4">
                  <div class="bg-slate-50 p-4 rounded-lg border border-slate-200">
                    <div class="text-sm text-slate-600 font-semibold mb-3">WORKING DAYS</div>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
                      <template x-for="day in [0, 1, 2, 3, 4, 5, 6]" :key="day">
                        <button
                          :class="selectedGroupDetail.workingDays.some(w => w.dayOfWeek === day) ? 'bg-blue-600 text-white' : 'bg-white text-slate-900 border border-slate-300'"
                          class="py-2 px-3 rounded-lg font-semibold transition"
                          :x-text="['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'][day]"
                        ></button>
                      </template>
                    </div>
                  </div>

                  <div class="bg-blue-50 border-2 border-blue-200 rounded-lg p-4">
                    <p class="text-sm text-blue-700">Schedule management coming in next phase.</p>
                  </div>
                </div>

                <!-- Trips Tab -->
                <div x-show="selectedTab === 'trips'" class="space-y-4">
                  <button
                    @click="openCreateTripDrawer()"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition"
                  >
                    + Add Trip
                  </button>

                  <template x-if="tripHistory.length > 0">
                    <div class="space-y-3">
                      <template x-for="trip in tripHistory" :key="trip.id">
                        <div class="bg-slate-50 p-4 rounded-lg border border-slate-200">
                          <div class="flex items-center justify-between mb-2">
                            <div class="font-semibold text-slate-900" x-text="new Date(trip.tripDate).toLocaleDateString('en-US', {year: 'numeric', month: 'short', day: 'numeric'})"></div>
                            <div class="text-sm text-slate-600" x-text="trip.actualDriverUserId ? 'Driver: ' + trip.actualDriverUserId : 'Pending'"></div>
                          </div>
                          <div class="text-sm text-slate-600" x-text="trip.notes || 'No notes'"></div>
                          <template x-if="trip.petrolAmount || trip.tollAmount">
                            <div class="mt-2 text-sm text-slate-600">
                              <span x-if="trip.petrolAmount" x-text="'Petrol: ₹' + trip.petrolAmount"></span>
                              <span x-if="trip.petrolAmount && trip.tollAmount"> | </span>
                              <span x-if="trip.tollAmount" x-text="'Toll: ₹' + trip.tollAmount"></span>
                            </div>
                          </template>
                        </div>
                      </template>
                    </div>
                  </template>

                  <template x-if="tripHistory.length === 0 && !isLoading">
                    <div class="text-center py-8 text-slate-600">
                      <p>No trips yet. Create one to get started.</p>
                    </div>
                  </template>
                </div>
              </div>
            </div>

            <!-- Error State -->
            <template x-if="error">
              <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-red-800">
                <div class="flex items-start justify-between">
                  <div>
                    <div class="font-semibold">Error</div>
                    <div class="text-sm" x-text="error"></div>
                  </div>
                  <button
                    @click="clearError()"
                    class="text-red-600 hover:text-red-800 font-bold"
                  >
                    ×
                  </button>
                </div>
              </div>
            </template>

            <!-- Loading State -->
            <template x-if="isLoading">
              <div class="text-center py-8">
                <div class="inline-block animate-spin">⚙️</div>
                <p class="text-slate-600 mt-2">Loading...</p>
              </div>
            </template>
          </div>
        </template>
      </div>
    </div>

    <!-- Create Group Drawer -->
    <div
      x-show="$store.carPoolApp.showCreateGroupDrawer"
      class="fixed inset-0 bg-black bg-opacity-50 flex items-end z-50"
    >
      <div class="bg-white w-full md:w-96 rounded-t-2xl md:rounded-2xl shadow-lg p-6 md:m-4 space-y-4">
        <h3 class="text-xl font-bold text-slate-900">Create Group</h3>

        <div class="space-y-3">
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Group Name</label>
            <input
              type="text"
              x-model="$store.carPoolApp.createGroupForm.name"
              placeholder="e.g., Downtown Office"
              class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Rotation Type</label>
            <select
              x-model="$store.carPoolApp.createGroupForm.rotationType"
              class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            >
              <option value="simple_rotation">Simple Rotation</option>
            </select>
            <p class="text-xs text-slate-500 mt-1">Complex rotation coming soon</p>
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Start Date</label>
            <input
              type="date"
              x-model="$store.carPoolApp.createGroupForm.startDate"
              class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>
        </div>

        <div class="flex gap-3">
          <button
            @click="$store.carPoolApp.closeCreateGroupDrawer()"
            class="flex-1 px-4 py-2 border border-slate-300 text-slate-700 font-semibold rounded-lg hover:bg-slate-50 transition"
          >
            Cancel
          </button>
          <button
            @click="$store.carPoolApp.submitCreateGroup()"
            :disabled="$store.carPoolApp.isLoading"
            class="flex-1 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition disabled:opacity-50"
          >
            Create
          </button>
        </div>
      </div>
    </div>

    <!-- Create Trip Drawer -->
    <div
      x-show="$store.carPoolApp.showCreateTripDrawer"
      class="fixed inset-0 bg-black bg-opacity-50 flex items-end z-50"
    >
      <div class="bg-white w-full md:w-96 rounded-t-2xl md:rounded-2xl shadow-lg p-6 md:m-4 space-y-4">
        <h3 class="text-xl font-bold text-slate-900">Add Trip</h3>

        <div class="space-y-3">
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Trip Date</label>
            <input
              type="date"
              x-model="$store.carPoolApp.createTripForm.tripDate"
              class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Driver (Optional)</label>
            <input
              type="text"
              x-model="$store.carPoolApp.createTripForm.actualDriverUserId"
              placeholder="User ID"
              class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1">Petrol (₹)</label>
              <input
                type="number"
                x-model.number="$store.carPoolApp.createTripForm.petrolAmount"
                placeholder="0"
                class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-slate-700 mb-1">Toll (₹)</label>
              <input
                type="number"
                x-model.number="$store.carPoolApp.createTripForm.tollAmount"
                placeholder="0"
                class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1">Notes (Optional)</label>
            <textarea
              x-model="$store.carPoolApp.createTripForm.notes"
              placeholder="Add any notes about this trip"
              rows="3"
              class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            ></textarea>
          </div>
        </div>

        <div class="flex gap-3">
          <button
            @click="$store.carPoolApp.closeCreateTripDrawer()"
            class="flex-1 px-4 py-2 border border-slate-300 text-slate-700 font-semibold rounded-lg hover:bg-slate-50 transition"
          >
            Cancel
          </button>
          <button
            @click="$store.carPoolApp.submitCreateTrip()"
            :disabled="$store.carPoolApp.isLoading"
            class="flex-1 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition disabled:opacity-50"
          >
            Add Trip
          </button>
        </div>
      </div>
    </div>
  </div>
</AppShell>
