---
import { AvCard, AvContainer, AvEmptyState } from "@ansiversa/components";
import { server } from "../../../../../actions";
import AppShell from "../../../../../layouts/AppShell.astro";

const { id, tripId } = Astro.params;
if (!id || !tripId) {
  throw new Error("Group ID and Trip ID are required");
}

let tripDetail = null;
let loadError: string | null = null;

try {
  const result = await Astro.callAction(server.loadTripDetail, { tripId });
  if (result?.error) {
    loadError = result.error.message ?? "Unable to load trip";
  }
  tripDetail = result?.data?.trip
    ? {
        trip: result.data.trip,
        participants: result.data.participants || [],
      }
    : null;
} catch (error) {
  console.error("Error loading trip detail:", error);
  loadError = error instanceof Error ? error.message : String(error);
}

if (!tripDetail && loadError) {
  return Astro.redirect(`/app/groups/${id}/trips`);
}

const initialState = {
  groupId: id,
  tripDetail,
  loadError,
};
---

<AppShell title="Trip details – Car Pool" description="Review one logged trip inside the Car Pool workspace.">
  <section class="av-section">
    <AvContainer>
      <div
        class="av-auth-stack-lg"
        x-data="$store.carPoolApp"
        x-init="initializeTripDetailPage($el.dataset.initial)"
        data-initial={JSON.stringify(initialState)}
      >
        <AvCard className="av-auth-stack-md">
          <div class="av-auth-stack-xs">
            <a href={`/app/groups/${id}/trips`} class="av-text-soft app-back-link">← Back to trips</a>
            <p class="av-kicker">Trip detail</p>
            <h1 class="av-section-title">Recorded commute</h1>
            <p class="av-text-soft">Driver, passengers, absences, and fairness impact stay grouped inside the app shell.</p>
          </div>

          <template x-if="error">
            <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
          </template>
        </AvCard>

        <template x-if="selectedTrip.trip">
          <div class="av-auth-stack-lg">
            <AvCard variant="soft" className="av-auth-stack-md">
              <div class="av-auth-stack-xs">
                <p class="av-kicker">Trip summary</p>
                <h2 class="av-card-heading" x-text="formatDate(selectedTrip.trip.tripDate)"></h2>
              </div>

              <div class="app-trip-summary">
                <div class="av-auth-stack-xxs">
                  <p class="app-stat-label">Driver</p>
                  <p class="app-hero-driver">
                    <span x-text="getTripDriverParticipant()?.member?.name || 'Driver not set'"></span>
                    drove
                  </p>
                </div>
                <div class="app-summary-lines">
                  <p class="av-text-soft">
                    Passengers:
                    <span x-text="getTripPassengerNames().length ? getTripPassengerNames().join(', ') : 'None'"></span>
                  </p>
                  <template x-if="getTripAbsentNames().length > 0">
                    <p class="av-text-soft">
                      Absent:
                      <span x-text="getTripAbsentNames().join(', ')"></span>
                    </p>
                  </template>
                </div>
              </div>

              <div class="app-stat-grid">
                <div class="app-stat-card">
                  <p class="app-stat-label">Passengers</p>
                  <p class="app-stat-value" x-text="getTripPassengerNames().length"></p>
                </div>
                <div class="app-stat-card">
                  <p class="app-stat-label">Absent</p>
                  <p class="app-stat-value" x-text="getTripAbsentNames().length"></p>
                </div>
              </div>

              <template x-if="selectedTrip.trip.notes">
                <p class="av-text-soft" x-text="selectedTrip.trip.notes"></p>
              </template>
            </AvCard>

            <AvCard variant="soft" className="av-auth-stack-md">
              <div class="av-auth-stack-xs">
                <p class="av-kicker">Participants</p>
                <h2 class="av-card-heading">Attendance</h2>
              </div>

              <div class="app-list-stack">
                <template x-for="participant in selectedTrip.participants" :key="participant.id">
                  <div class="app-list-row">
                    <div class="av-auth-stack-xxs">
                      <span class="app-list-title" x-text="participant.member?.name || 'Unknown member'"></span>
                      <p class="av-text-soft">
                        Fairness impact:
                        <span x-text="getParticipantImpactLabel(participant)"></span>
                      </p>
                    </div>
                    <div class="app-row-end">
                      <span
                        class="app-status-pill"
                        :class="getParticipantRoleClass(participant)"
                        x-text="getParticipantRoleLabel(participant)"
                      ></span>
                      <span class="app-score-pill" x-text="getParticipantImpactLabel(participant)"></span>
                    </div>
                  </div>
                </template>
              </div>
            </AvCard>
          </div>
        </template>

        <template x-if="!selectedTrip.trip && !isLoading">
          <AvCard variant="soft">
            <AvEmptyState
              headline="Trip unavailable"
              description="This trip could not be loaded for the current user."
            />
          </AvCard>
        </template>
      </div>
    </AvContainer>
  </section>
</AppShell>
