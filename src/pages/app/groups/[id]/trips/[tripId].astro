---
import {
  AvButton,
  AvCard,
  AvCheckbox,
  AvContainer,
  AvDrawer,
  AvEmptyState,
  AvInput,
  AvSelect,
  AvTextarea,
} from "@ansiversa/components";
import { server } from "../../../../../actions";
import AppShell from "../../../../../layouts/AppShell.astro";

const { id, tripId } = Astro.params;
if (!id || !tripId) {
  throw new Error("Group ID and Trip ID are required");
}

let tripDetail = null;
let groupDetail = null;
let loadError: string | null = null;

try {
  const [tripResult, groupResult] = await Promise.all([
    Astro.callAction(server.loadTripDetail, { tripId }),
    Astro.callAction(server.loadGroupDetail, { groupId: id }),
  ]);

  if (tripResult?.error || groupResult?.error) {
    loadError = tripResult?.error?.message ?? groupResult?.error?.message ?? "Unable to load trip";
  }

  tripDetail = tripResult?.data?.trip
    ? {
        trip: tripResult.data.trip,
        participants: tripResult.data.participants || [],
      }
    : null;
  groupDetail = groupResult?.data?.group
    ? {
        group: groupResult.data.group,
        members: groupResult.data.members || [],
      }
    : null;
} catch (error) {
  console.error("Error loading trip detail:", error);
  loadError = error instanceof Error ? error.message : String(error);
}

if (!tripDetail && loadError) {
  return Astro.redirect(`/app/groups/${id}/trips`);
}

const initialState = {
  groupId: id,
  tripDetail,
  groupDetail,
  loadError,
};
---

<AppShell title="Trip details – Car Pool" description="Review one logged trip inside the Car Pool workspace.">
  <section class="av-section">
    <AvContainer>
      <div
        class="av-auth-stack-lg"
        x-data="$store.carPoolApp"
        x-init="initializeTripDetailPage($el.dataset.initial)"
        data-initial={JSON.stringify(initialState)}
      >
        <AvCard className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div class="av-auth-stack-xs">
              <a href={`/app/groups/${id}/trips`} class="av-text-soft app-back-link">← Back to trips</a>
              <p class="av-kicker">Trip detail</p>
              <h1 class="av-section-title">Recorded commute</h1>
              <p class="av-text-soft">Driver, passengers, absences, and fairness impact stay grouped inside the app shell.</p>
            </div>
            <div class="av-row-wrap">
              <AvButton type="button" @click="openEditTripDrawer(selectedTrip.trip.id)" :disabled="!selectedTrip.trip">
                Edit trip
              </AvButton>
            </div>
          </div>

          <template x-if="error">
            <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
          </template>
        </AvCard>

        <template x-if="selectedTrip.trip">
          <div class="av-auth-stack-lg">
            <AvCard variant="soft" className="av-auth-stack-md">
              <div class="av-auth-stack-xs">
                <p class="av-kicker">Trip summary</p>
                <h2 class="av-card-heading" x-text="formatDate(selectedTrip.trip.tripDate)"></h2>
              </div>

              <div class="app-trip-summary">
                <div class="av-auth-stack-xxs">
                  <p class="app-stat-label">Driver</p>
                  <p class="app-hero-driver">
                    <span x-text="getTripDriverParticipant()?.member?.name || 'Driver not set'"></span>
                    drove
                  </p>
                </div>
                <div class="app-summary-lines">
                  <p class="av-text-soft">
                    Passengers:
                    <span x-text="getTripPassengerNames().length ? getTripPassengerNames().join(', ') : 'None'"></span>
                  </p>
                  <template x-if="getTripAbsentNames().length > 0">
                    <p class="av-text-soft">
                      Absent:
                      <span x-text="getTripAbsentNames().join(', ')"></span>
                    </p>
                  </template>
                </div>
              </div>

              <div class="app-stat-grid">
                <div class="app-stat-card">
                  <p class="app-stat-label">Passengers</p>
                  <p class="app-stat-value" x-text="getTripPassengerNames().length"></p>
                </div>
                <div class="app-stat-card">
                  <p class="app-stat-label">Absent</p>
                  <p class="app-stat-value" x-text="getTripAbsentNames().length"></p>
                </div>
              </div>

              <template x-if="selectedTrip.trip.notes">
                <p class="av-text-soft" x-text="selectedTrip.trip.notes"></p>
              </template>
            </AvCard>

            <AvCard variant="soft" className="av-auth-stack-md">
              <div class="av-auth-stack-xs">
                <p class="av-kicker">Participants</p>
                <h2 class="av-card-heading">Attendance</h2>
              </div>

              <div class="app-list-stack">
                <template x-for="participant in selectedTrip.participants" :key="participant.id">
                  <div class="app-list-row">
                    <div class="av-auth-stack-xxs">
                      <span class="app-list-title" x-text="participant.member?.name || 'Unknown member'"></span>
                      <p class="av-text-soft">
                        Fairness impact:
                        <span x-text="getParticipantImpactLabel(participant)"></span>
                      </p>
                    </div>
                    <div class="app-row-end">
                      <span
                        class="app-status-pill"
                        :class="getParticipantRoleClass(participant)"
                        x-text="getParticipantRoleLabel(participant)"
                      ></span>
                      <span class="app-score-pill" x-text="getParticipantImpactLabel(participant)"></span>
                    </div>
                  </div>
                </template>
              </div>
            </AvCard>
          </div>
        </template>

        <template x-if="!selectedTrip.trip && !isLoading">
          <AvCard variant="soft">
            <AvEmptyState
              headline="Trip unavailable"
              description="This trip could not be loaded for the current user."
            />
          </AvCard>
        </template>

        <template x-if="showCreateTripDrawer">
          <div
            class="av-drawer-overlay"
            @click.self="closeCreateTripDrawer()"
            @keydown.escape.window="closeCreateTripDrawer()"
            @close-drawer="closeCreateTripDrawer()"
            x-cloak
          >
            <AvDrawer title="Edit trip" description="Correct this commute record without leaving the trip detail page.">
              <form id="edit-trip-form" class="av-auth-stack-md" @submit.prevent="submitCreateTrip()">
                <AvInput
                  label="Date"
                  name="trip-date"
                  type="date"
                  className="app-drawer-section"
                  x-model="createTripForm.tripDate"
                  @change="onTripDateChange()"
                  required
                />

                <AvSelect
                  label="Driver"
                  name="actual-driver"
                  className="app-drawer-section"
                  x-model="createTripForm.actualDriverId"
                  x-effect="$el.value = createTripForm.actualDriverId"
                  @change="onTripDriverChange()"
                  required
                >
                  <option value="">Select driver</option>
                  <template x-for="member in selectedGroupDetail.members" :key="member.id">
                    <option
                      :value="String(member.id)"
                      :selected="String(member.id) === createTripForm.actualDriverId"
                      x-text="member.name"
                    ></option>
                  </template>
                </AvSelect>

                <div class="app-field app-drawer-section">
                  <span class="app-label">Present passengers</span>
                  <p class="av-text-soft">Select riders who joined this commute. The driver is excluded.</p>
                  <div class="app-checklist">
                    <template x-for="member in getTripPassengerOptions()" :key="`${member.id}-passenger-edit`">
                      <AvCheckbox
                        className="app-check-item"
                        :value="member.id"
                        x-model="createTripForm.passengers"
                      >
                        <span x-text="member.name"></span>
                      </AvCheckbox>
                    </template>
                  </div>
                </div>

                <div class="app-field app-drawer-section app-drawer-section--muted">
                  <span class="app-label">Absentees</span>
                  <p class="av-text-soft">Use only for members who missed this trip. The driver is excluded.</p>
                  <div class="app-checklist">
                    <template x-for="member in getTripAbsenteeOptions()" :key="`${member.id}-absent-edit`">
                      <AvCheckbox
                        className="app-check-item"
                        :value="member.id"
                        x-model="createTripForm.absentees"
                        :disabled="createTripForm.passengers.includes(member.id)"
                      >
                        <span x-text="member.name"></span>
                      </AvCheckbox>
                    </template>
                  </div>
                </div>

                <AvTextarea
                  label="Notes"
                  name="trip-notes"
                  rows={3}
                  x-model="createTripForm.notes"
                  placeholder="Optional trip notes"
                />
              </form>

              <Fragment slot="footer">
                <div class="av-auth-stack-xs av-w-full">
                  <template x-if="error">
                    <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
                  </template>
                  <div class="av-row-wrap av-drawer-footer-actions">
                    <AvButton variant="ghost" type="button" @click="closeCreateTripDrawer()">Cancel</AvButton>
                    <AvButton type="submit" form="edit-trip-form" :disabled="isLoading">
                      <span x-text="isLoading ? 'Saving…' : 'Save changes'"></span>
                    </AvButton>
                  </div>
                </div>
              </Fragment>
            </AvDrawer>
          </div>
        </template>
      </div>
    </AvContainer>
  </section>
</AppShell>
