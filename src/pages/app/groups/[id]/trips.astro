---
import { AvButton, AvCard, AvContainer, AvEmptyState, AvIcon, AvSelect } from "@ansiversa/components";
import { server } from "../../../../actions";
import AppShell from "../../../../layouts/AppShell.astro";
import type { CarPoolTrip } from "../../../../modules/app/carPoolStore";

const { id } = Astro.params;
if (!id) {
  throw new Error("Group ID is required");
}

let tripHistory: CarPoolTrip[] = [];
let groupDetail = null;
let loadError: string | null = null;

try {
  const [tripResult, detailResult] = await Promise.all([
    Astro.callAction(server.listTripHistory, { groupId: id, limit: 500 }),
    Astro.callAction(server.loadGroupDetail, { groupId: id }),
  ]);

  if (tripResult?.error || detailResult?.error) {
    loadError = tripResult?.error?.message ?? detailResult?.error?.message ?? "Unable to load trip history";
  }

  tripHistory = (tripResult?.data?.trips as any) || [];
  groupDetail = detailResult?.data?.group
    ? {
        group: detailResult.data.group,
        members: detailResult.data.members || [],
      }
    : null;
} catch (error) {
  console.error("Error loading trip history:", error);
  loadError = error instanceof Error ? error.message : String(error);
}

if (loadError && !groupDetail) {
  return Astro.redirect("/app");
}

const initialState = {
  groupId: id,
  groupDetail,
  tripHistory,
  loadError,
};

const groupName = groupDetail?.group?.name ?? "Group";
---

<AppShell title={`Trips – ${groupName}`} description="Review the Car Pool trip log inside the protected workspace.">
  <section class="av-section">
    <AvContainer>
      <div
        class="av-auth-stack-lg"
        x-data="$store.carPoolApp"
        x-init="initializeTripHistoryPage($el.dataset.initial)"
        data-initial={JSON.stringify(initialState)}
      >
        <AvCard className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div class="av-auth-stack-xs">
              <a href={`/app/groups/${id}`} class="av-text-soft app-back-link">← Back to group</a>
              <p class="av-kicker">Trips</p>
              <h1 class="av-section-title">{groupName} trip history</h1>
              <p class="av-text-soft">All logged trips stay inside the same app workspace instead of floating outside the shell.</p>
            </div>
            <div class="av-row-wrap">
              <AvButton type="button" variant="ghost" href={`/app/groups/${id}`}>Group overview</AvButton>
            </div>
          </div>

          <template x-if="error">
            <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
          </template>
        </AvCard>

        <AvCard variant="soft" className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div>
              <p class="av-kicker">Workspace</p>
              <h2 class="av-card-heading">Logged trips</h2>
            </div>
            <p class="av-text-soft">
              <span x-text="getTripHistoryVisibleCount()"></span>
              <span x-show="tripHistoryMemberFilter"> filtered</span>
              <span x-show="!tripHistoryMemberFilter"> total</span>
            </p>
          </div>

          <div class="app-history-filter">
            <AvSelect
              label="Filter by member"
              name="trip-history-member-filter"
              x-model="tripHistoryMemberFilter"
              @change="onTripHistoryMemberFilterChange()"
            >
              <option value="">All members</option>
              <template x-for="member in selectedGroupDetail.members" :key="`${member.id}-history-filter`">
                <option :value="member.id" x-text="member.name"></option>
              </template>
            </AvSelect>
            <template x-if="tripHistoryMemberFilter">
              <AvSelect
                label="Role"
                name="trip-history-role-filter"
                x-model="tripHistoryRoleFilter"
                @change="onTripHistoryRoleFilterChange()"
              >
                <option value="driver">Driver</option>
                <option value="passenger">Passenger</option>
                <option value="absent">Absent</option>
                <option value="any">Any role</option>
              </AvSelect>
            </template>
            <p class="av-text-soft">Filter trips where the selected member was driver, passenger, or absent.</p>
          </div>

          <template x-if="tripHistory.length === 0">
            <AvEmptyState
              headline="No trips logged yet"
              description="Return to the group workspace and use the standard trip drawer to record the first commute."
            />
          </template>

          <template x-if="tripHistory.length > 0 && getFilteredTripHistory().length === 0">
            <AvEmptyState
              headline="No trips found for this member."
              description="Choose All members to return to the full trip history."
            />
          </template>

          <template x-if="getFilteredTripHistory().length > 0">
            <div class="app-list-stack">
              <template x-for="trip in getPaginatedTripHistory()" :key="trip.id">
                <div class="app-list-row">
                  <div class="av-auth-stack-xxs">
                    <span class="app-list-title" x-text="formatDate(trip.tripDate)"></span>
                    <p class="av-text-soft">
                      Passengers: <span x-text="trip.passengerCount || 0"></span>
                      · Absent: <span x-text="trip.absenteeCount || 0"></span>
                    </p>
                  </div>
                  <AvButton
                    type="button"
                    size="sm"
                    variant="ghost"
                    className="app-icon-button"
                    aria-label="View trip"
                    title="View trip"
                    @click="navigateToTripDetail(trip.id)"
                  >
                    <AvIcon name="eye" size="sm" />
                  </AvButton>
                </div>
              </template>
            </div>
          </template>

          <template x-if="getFilteredTripHistory().length > tripHistoryPageSize">
            <div class="app-pagination" aria-label="Trip history pagination">
              <p class="av-text-soft" x-text="getTripHistoryPageLabel()"></p>
              <div class="av-row-wrap">
                <AvButton
                  type="button"
                  size="sm"
                  variant="ghost"
                  @click="previousTripHistoryPage()"
                  :disabled="tripHistoryPage <= 1"
                >
                  Previous
                </AvButton>
                <AvButton
                  type="button"
                  size="sm"
                  variant="ghost"
                  @click="nextTripHistoryPage()"
                  :disabled="tripHistoryPage >= getTripHistoryPageCount()"
                >
                  Next
                </AvButton>
              </div>
            </div>
          </template>
        </AvCard>
      </div>
    </AvContainer>
  </section>
</AppShell>
