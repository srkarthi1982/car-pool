---
import {
  AvButton,
  AvCard,
  AvCheckbox,
  AvConfirmDialog,
  AvContainer,
  AvDrawer,
  AvEmptyState,
  AvIcon,
  AvInput,
  AvSelect,
  AvTextarea,
} from "@ansiversa/components";
import { server } from "../../../actions";
import AppShell from "../../../layouts/AppShell.astro";
import type { CarPoolTrip } from "../../../modules/app/carPoolStore";

export async function getStaticPaths() {
  return [];
}

const { id } = Astro.params;
if (!id) {
  throw new Error("Group ID is required");
}

let groupDetail = null;
let tripHistory: CarPoolTrip[] = [];
let loadError: string | null = null;

try {
  const [detailResult, tripResult] = await Promise.all([
    Astro.callAction(server.loadGroupDetail, { groupId: id }),
    Astro.callAction(server.listTripHistory, { groupId: id }),
  ]);

  if (detailResult?.error || tripResult?.error) {
    loadError = detailResult?.error?.message ?? tripResult?.error?.message ?? "Unable to load group workspace";
  }

  groupDetail = detailResult?.data?.group
    ? {
        group: detailResult.data.group,
        members: detailResult.data.members || [],
      }
    : null;
  tripHistory = (tripResult?.data?.trips as any) || [];
} catch (error) {
  console.error("Error loading group workspace:", error);
  loadError = error instanceof Error ? error.message : String(error);
}

if (!groupDetail && loadError) {
  return Astro.redirect("/app");
}

const initialState = {
  groupId: id,
  groupDetail,
  tripHistory,
  loadError,
  currentUser: Astro.locals.user
    ? {
        id: Astro.locals.user.id,
        roleId: Astro.locals.user.roleId ?? null,
      }
    : null,
};

const groupName = groupDetail?.group?.name ?? "Group workspace";
---

<AppShell title={`${groupName} – Car Pool`} description="Manage members, trips, and fairness inside the Car Pool workspace.">
  <section class="av-section">
    <AvContainer>
      <div
        class="av-auth-stack-lg"
        x-data="$store.carPoolApp"
        x-init="initializeGroupWorkspace($el.dataset.initial)"
        data-initial={JSON.stringify(initialState)}
      >
        <AvCard className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div class="av-auth-stack-xs">
              <a href="/app" class="av-text-soft app-back-link">← Back to groups</a>
              <p class="av-kicker">Car Pool</p>
              <div class="app-title-row">
                <h1 class="av-section-title" x-text={`selectedGroupDetail.group?.name || ${JSON.stringify(groupName)}`}>{groupName}</h1>
                <template x-if="canManageSelectedGroup()">
                  <AvButton
                    type="button"
                    size="sm"
                    variant="ghost"
                    className="app-icon-button"
                    aria-label="Edit group"
                    title="Edit group"
                    @click="openEditGroupDrawer()"
                  >
                    <AvIcon name="edit" size="sm" />
                  </AvButton>
                </template>
              </div>
              <p class="av-text-soft">Overview, members, trips, and fairness stay together in one protected workspace.</p>
            </div>
            <div class="av-row-wrap">
              <template x-if="canManageSelectedGroup()">
                <AvButton type="button" variant="ghost" @click="openAddMembersDrawer()">Add members</AvButton>
              </template>
              <AvButton
                type="button"
                @click="openCreateTripDrawer()"
                :disabled="selectedGroupDetail.group?.isArchived || !hasValidTravellerSelection()"
              >
                Log trip
              </AvButton>
            </div>
          </div>

          <template x-if="error">
            <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
          </template>
        </AvCard>

        <template x-if="selectedGroupDetail.group">
          <div class="av-auth-stack-lg">
            <AvCard variant="soft" className="av-auth-stack-md">
              <div class="av-auth-stack-xs">
                <p class="av-kicker">Today’s travelling members</p>
                <h2 class="av-card-heading">Active rotation set</h2>
                <p class="av-text-soft">Choose who is travelling today. Driver suggestion and preview will use this active set only.</p>
              </div>

              <div class="app-traveller-grid">
                <template x-for="member in selectedGroupDetail.members.filter((member) => member.isActive !== false)" :key="`${member.id}-traveller`">
                  <AvCheckbox
                    className="app-traveller-chip"
                    :value="member.id"
                    x-model="travellingMemberIds"
                    @change="onTravellingMembersChange()"
                  >
                    <span x-text="member.name"></span>
                  </AvCheckbox>
                </template>
              </div>

              <div class="av-row-between app-row-top">
                <p class="av-text-soft">
                  <span x-text="getTravellingMemberCount()"></span>
                  <span> travelling today</span>
                </p>
                <template x-if="!hasValidTravellerSelection()">
                  <div class="av-alert av-alert-danger app-inline-warning" role="status">
                    Select at least 2 travelling members to calculate today’s rotation.
                  </div>
                </template>
              </div>
            </AvCard>

            <div class="app-section-grid">
              <AvCard variant="soft" className="av-auth-stack-md">
                <div class="av-auth-stack-xs">
                  <p class="av-kicker">Overview</p>
                  <h2 class="av-card-heading">Rotation snapshot</h2>
                  <p class="av-text-soft">Driver suggestion uses the selected travelling members and their full group history.</p>
                </div>

                <div class="app-overview-grid">
                  <div class="app-stat-card app-stat-card--hero">
                    <p class="app-stat-label">Today’s driver</p>
                    <p class="app-stat-hint">Suggested by today’s travelling set + global fairness</p>
                    <template x-if="getTodaysDriver()">
                      <div class="av-auth-stack-xxs">
                        <p class="app-hero-driver" x-text="getTodaysDriver().name"></p>
                        <span
                          class="app-status-pill"
                          :class="getFairnessStatusClass(getTodaysDriver())"
                          x-text="getFairnessStatus(getTodaysDriver())"
                        ></span>
                      </div>
                    </template>
                    <template x-if="!getTodaysDriver()">
                      <p class="av-text-soft">Select at least 2 travelling members to calculate today’s rotation.</p>
                    </template>
                  </div>

                  <div class="app-stat-card">
                    <p class="app-stat-label">Group status</p>
                    <p class="app-stat-value" x-text="selectedGroupDetail.group.isArchived ? 'Archived' : 'Active'"></p>
                    <p class="av-text-soft">Working days: <span x-text="Array.isArray(selectedGroupDetail.group.workingDays) ? selectedGroupDetail.group.workingDays.length : 0"></span></p>
                  </div>
                </div>

                <div class="av-auth-stack-xs">
                  <div>
                    <p class="app-stat-label">Next drivers</p>
                    <p class="av-text-soft">Upcoming preview for today’s travelling set</p>
                  </div>
                  <div class="app-list-stack">
                    <template x-for="preview in getNextDriverPreview(3)" :key="preview.id">
                      <div class="app-list-row">
                        <div class="av-auth-stack-xxs">
                          <span class="app-list-title" x-text="preview.driver.name"></span>
                          <span class="av-text-soft">Next scheduled driver</span>
                        </div>
                        <span class="app-date-pill" x-text="formatShortDate(preview.date)"></span>
                      </div>
                    </template>
                  </div>
                </div>
              </AvCard>

              <AvCard variant="soft" className="av-auth-stack-md">
                <div class="av-auth-stack-xs">
                  <p class="av-kicker">Members</p>
                  <h2 class="av-card-heading">Team roster</h2>
                  <p class="av-text-soft">Members appear in the group workspace with their current fairness counts.</p>
                </div>

                <template x-if="selectedGroupDetail.members.length === 0">
                  <AvEmptyState
                    headline="No members yet"
                    description="Add members to start building a real commute rotation."
                  />
                </template>

                <template x-if="selectedGroupDetail.members.length > 0">
                  <div class="app-list-stack">
                    <template x-for="member in selectedGroupDetail.members" :key="member.id">
                      <div class="app-list-row">
                        <div class="av-auth-stack-xxs">
                          <span class="app-list-title" x-text="member.name"></span>
                          <p class="av-text-soft">
                            Drives: <span x-text="member.fairness?.driveCount || 0"></span>
                            · Rides: <span x-text="member.fairness?.rideCount || 0"></span>
                            · Absences: <span x-text="member.fairness?.absenceCount || 0"></span>
                          </p>
                        </div>
                        <div class="app-row-end">
                          <span
                            class="app-status-pill"
                            :class="getFairnessStatusClass(member)"
                            x-text="getFairnessStatus(member)"
                          ></span>
                          <span class="app-score-pill" x-text="getFairnessScore(member)"></span>
                          <template x-if="canManageSelectedGroup()">
                            <div class="app-trip-actions" aria-label="Member actions">
                              <AvButton
                                type="button"
                                size="sm"
                                variant="ghost"
                                className="app-icon-button"
                                aria-label="Edit member name"
                                title="Edit member name"
                                @click="openEditMemberDrawer(member.id)"
                              >
                                <AvIcon name="edit" size="sm" />
                              </AvButton>
                              <AvButton
                                type="button"
                                size="sm"
                                variant="ghost"
                                className="app-icon-button app-icon-button--danger"
                                aria-label="Remove member"
                                title="Remove member"
                                @click="openRemoveMemberConfirm(member.id)"
                              >
                                <AvIcon name="trash" size="sm" />
                              </AvButton>
                            </div>
                          </template>
                        </div>
                      </div>
                    </template>
                  </div>
                </template>
              </AvCard>
            </div>

            <div class="app-section-grid">
              <AvCard variant="soft" className="av-auth-stack-md">
                <div class="av-row-between app-row-top">
                  <div class="av-auth-stack-xs">
                    <p class="av-kicker">Trips</p>
                    <h2 class="av-card-heading">Recent trip log</h2>
                    <p class="av-text-soft">Each commute shows the driver, rider count, and absences at a glance.</p>
                  </div>
                  <div class="av-row-wrap">
                    <AvButton type="button" variant="ghost" @click="navigateToTripHistory()">View all trips</AvButton>
                    <AvButton
                      type="button"
                      @click="openCreateTripDrawer()"
                      :disabled="selectedGroupDetail.group?.isArchived || !hasValidTravellerSelection()"
                    >
                      Log trip
                    </AvButton>
                  </div>
                </div>

                <template x-if="tripHistory.length === 0">
                  <AvEmptyState
                    headline="No trips logged yet"
                    description="Your first trip entry will appear here with driver and attendance details."
                  />
                </template>

                <template x-if="tripHistory.length > 0">
                  <div class="app-list-stack">
                    <template x-for="trip in tripHistory.slice(0, 5)" :key="trip.id">
                      <div class="app-list-row">
                        <div class="av-auth-stack-xxs">
                          <span class="app-list-title" x-text="formatDate(trip.tripDate)"></span>
                          <p class="av-text-soft">
                            Driver: <span x-text="getTripDriverName(trip)"></span>
                            ·
                            Passengers: <span x-text="trip.passengerCount || 0"></span>
                            · Absent: <span x-text="trip.absenteeCount || 0"></span>
                          </p>
                        </div>
                        <div class="app-trip-actions" aria-label="Trip actions">
                          <AvButton
                            type="button"
                            size="sm"
                            variant="ghost"
                            className="app-icon-button"
                            aria-label="Edit trip"
                            title="Edit trip"
                            @click="openEditTripDrawer(trip.id)"
                            :disabled="selectedGroupDetail.group?.isArchived"
                          >
                            <AvIcon name="edit" size="sm" />
                          </AvButton>
                          <AvButton
                            type="button"
                            size="sm"
                            variant="ghost"
                            className="app-icon-button"
                            aria-label="View trip"
                            title="View trip"
                            @click="navigateToTripDetail(trip.id)"
                          >
                            <AvIcon name="eye" size="sm" />
                          </AvButton>
                        </div>
                      </div>
                    </template>
                  </div>
                </template>
              </AvCard>

              <AvCard variant="soft" className="av-auth-stack-md">
                <div class="av-auth-stack-xs">
                  <p class="av-kicker">Fairness</p>
                  <h2 class="av-card-heading">Contribution balance</h2>
                  <p class="av-text-soft">Positive means the member has driven more than they have ridden.</p>
                </div>

                <template x-if="selectedGroupDetail.members.length === 0">
                  <p class="av-text-soft">Fairness appears once members and trips exist.</p>
                </template>

                <template x-if="selectedGroupDetail.members.length > 0">
                  <div class="app-list-stack">
                    <template x-for="member in selectedGroupDetail.members" :key="member.id">
                      <div class="app-fairness-row">
                        <div class="av-auth-stack-xxs">
                          <span class="app-list-title" x-text="member.name"></span>
                          <p class="av-text-soft">
                            Score: <span x-text="getFairnessScore(member)"></span>
                            · Missed rides: <span x-text="member.fairness?.missedRideCount || 0"></span>
                          </p>
                        </div>
                        <div class="app-fairness-meter">
                          <div
                            class="app-fairness-meter__fill"
                            :style="`width: ${Math.min(100, Math.max(8, 50 + (getFairnessScore(member) * 10)))}%`"
                          ></div>
                        </div>
                        <div class="app-row-end">
                          <span
                            class="app-status-pill"
                            :class="getFairnessStatusClass(member)"
                            x-text="getFairnessStatus(member)"
                          ></span>
                          <span class="app-score-pill" x-text="getFairnessScore(member)"></span>
                        </div>
                      </div>
                    </template>
                  </div>
                </template>
              </AvCard>
            </div>

            <template x-if="canDeleteSelectedGroup()">
              <AvCard variant="soft" className="av-auth-stack-sm app-danger-zone">
                <div class="av-row-between app-row-top">
                  <div class="av-auth-stack-xxs">
                    <p class="av-kicker">Danger zone</p>
                    <h2 class="av-card-heading">Delete group</h2>
                    <p class="av-text-soft">Permanently remove this group, its members, trips, and attendance history.</p>
                  </div>
                  <AvButton
                    type="button"
                    variant="outline"
                    className="app-danger-button"
                    @click="openDeleteGroupConfirm()"
                    :disabled="isLoading"
                  >
                    Delete group
                  </AvButton>
                </div>
              </AvCard>
            </template>
          </div>
        </template>

        <template x-if="!selectedGroupDetail.group && !isLoading">
          <AvCard variant="soft">
            <AvEmptyState
              headline="Group unavailable"
              description="This workspace could not be loaded for the current user."
            />
          </AvCard>
        </template>

        <template x-if="showEditGroupDrawer">
          <div
            class="av-drawer-overlay"
            @click.self="closeEditGroupDrawer()"
            @keydown.escape.window="closeEditGroupDrawer()"
            @close-drawer="closeEditGroupDrawer()"
            x-cloak
          >
            <AvDrawer title="Edit group" description="Rename this car pool group for everyone in the workspace.">
              <form id="edit-group-form" class="av-auth-stack-md" @submit.prevent="submitEditGroup()">
                <AvInput
                  label="Group name"
                  name="edit-group-name"
                  x-model="editGroupForm.name"
                  required
                />
              </form>

              <Fragment slot="footer">
                <div class="av-auth-stack-xs av-w-full">
                  <template x-if="error">
                    <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
                  </template>
                  <div class="av-row-wrap av-drawer-footer-actions">
                    <AvButton variant="ghost" type="button" @click="closeEditGroupDrawer()">Cancel</AvButton>
                    <AvButton type="submit" form="edit-group-form" :disabled="isLoading">
                      <span x-text="isLoading ? 'Saving…' : 'Save group'"></span>
                    </AvButton>
                  </div>
                </div>
              </Fragment>
            </AvDrawer>
          </div>
        </template>

        <template x-if="showAddMembersDrawer">
          <div
            class="av-drawer-overlay"
            @click.self="closeAddMembersDrawer()"
            @keydown.escape.window="closeAddMembersDrawer()"
            @close-drawer="closeAddMembersDrawer()"
            x-cloak
          >
            <AvDrawer title="Add members" description="Add members into this car pool workspace.">
              <div class="av-auth-stack-md">
                <div class="app-drawer-note">
                  <p class="app-list-title">Members are added in rotation order.</p>
                  <p class="av-text-soft" x-show="selectedGroupDetail.members.length > 0">
                    New members are added after the current rotation order.
                  </p>
                </div>

                <AvInput
                  label="Quick add member"
                  name="member-name"
                  placeholder="Enter member name and press Enter"
                  @keydown.enter.prevent="if ($event.target.value.trim()) { addMemberToForm('user_' + Date.now(), $event.target.value.trim()); $event.target.value = ''; }"
                />

                <div class="av-auth-stack-xs">
                  <p class="app-label">Staged members</p>
                  <template x-if="addMembersForm.members.length === 0">
                    <p class="av-text-soft">No members queued yet.</p>
                  </template>
                  <template x-if="addMembersForm.members.length > 0">
                    <div class="app-list-stack">
                      <template x-for="(member, index) in addMembersForm.members" :key="`${member.userId}-${index}`">
                        <div class="app-list-row">
                          <div class="av-auth-stack-xxs">
                            <span class="app-list-title" x-text="member.name"></span>
                            <span class="av-text-soft">Queued for next rotation slot</span>
                          </div>
                          <AvButton type="button" size="sm" variant="ghost" @click="removeMemberFromForm(index)">Remove</AvButton>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </div>

              <Fragment slot="footer">
                <div class="av-auth-stack-xs av-w-full">
                  <template x-if="error">
                    <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
                  </template>
                  <div class="av-row-wrap av-drawer-footer-actions">
                    <AvButton variant="ghost" type="button" @click="closeAddMembersDrawer()">Cancel</AvButton>
                    <AvButton type="button" @click="submitAddMembers()" :disabled="isLoading || addMembersForm.members.length === 0">
                      <span x-text="isLoading ? 'Adding…' : 'Add members'"></span>
                    </AvButton>
                  </div>
                </div>
              </Fragment>
            </AvDrawer>
          </div>
        </template>

        <template x-if="showEditMemberDrawer">
          <div
            class="av-drawer-overlay"
            @click.self="closeEditMemberDrawer()"
            @keydown.escape.window="closeEditMemberDrawer()"
            @close-drawer="closeEditMemberDrawer()"
            x-cloak
          >
            <AvDrawer title="Edit member name" description="Rename this member inside this group only.">
              <form id="edit-member-form" class="av-auth-stack-md" @submit.prevent="submitEditMember()">
                <AvInput
                  label="Member display name"
                  name="edit-member-name"
                  x-model="editMemberForm.name"
                  required
                />
              </form>

              <Fragment slot="footer">
                <div class="av-auth-stack-xs av-w-full">
                  <template x-if="error">
                    <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
                  </template>
                  <div class="av-row-wrap av-drawer-footer-actions">
                    <AvButton variant="ghost" type="button" @click="closeEditMemberDrawer()">Cancel</AvButton>
                    <AvButton type="submit" form="edit-member-form" :disabled="isLoading">
                      <span x-text="isLoading ? 'Saving…' : 'Save member'"></span>
                    </AvButton>
                  </div>
                </div>
              </Fragment>
            </AvDrawer>
          </div>
        </template>

        <template x-if="showCreateTripDrawer">
          <div
            class="av-drawer-overlay"
            @click.self="closeCreateTripDrawer()"
            @keydown.escape.window="closeCreateTripDrawer()"
            @close-drawer="closeCreateTripDrawer()"
            x-cloak
          >
            <AvDrawer title="Log or edit trip" description="Record or correct one commute without leaving the group workspace.">
              <form id="create-trip-form" class="av-auth-stack-md" @submit.prevent="submitCreateTrip()">
                <AvInput
                  label="Date"
                  name="trip-date"
                  type="date"
                  className="app-drawer-section"
                  x-model="createTripForm.tripDate"
                  @change="onTripDateChange()"
                  required
                />

                <AvSelect
                  label="Driver"
                  name="actual-driver"
                  className="app-drawer-section"
                  x-model="createTripForm.actualDriverId"
                  x-effect="$el.value = createTripForm.actualDriverId"
                  @change="onTripDriverChange()"
                  required
                >
                  <option value="">Select driver</option>
                  <template x-for="member in selectedGroupDetail.members" :key="member.id">
                    <option
                      :value="String(member.id)"
                      :selected="String(member.id) === createTripForm.actualDriverId"
                      x-text="member.name"
                    ></option>
                  </template>
                </AvSelect>

                <div class="app-field app-drawer-section">
                  <span class="app-label">Present passengers</span>
                  <p class="av-text-soft">Select riders who joined this commute. The driver is excluded.</p>
                  <div class="app-checklist">
                    <template x-for="member in getTripPassengerOptions()" :key="`${member.id}-passenger`">
                      <AvCheckbox
                        className="app-check-item"
                        :value="member.id"
                        x-model="createTripForm.passengers"
                      >
                        <span x-text="member.name"></span>
                      </AvCheckbox>
                    </template>
                  </div>
                </div>

                <div class="app-field app-drawer-section app-drawer-section--muted">
                  <span class="app-label">Absentees</span>
                  <p class="av-text-soft">Use only for members who missed this trip. The driver is excluded.</p>
                  <div class="app-checklist">
                    <template x-for="member in getTripAbsenteeOptions()" :key="`${member.id}-absent`">
                      <AvCheckbox
                        className="app-check-item"
                        :value="member.id"
                        x-model="createTripForm.absentees"
                        :disabled="createTripForm.passengers.includes(member.id)"
                      >
                        <span x-text="member.name"></span>
                      </AvCheckbox>
                    </template>
                  </div>
                </div>

                <AvTextarea
                  label="Notes"
                  name="trip-notes"
                  rows={3}
                  x-model="createTripForm.notes"
                  placeholder="Optional trip notes"
                />
              </form>

              <Fragment slot="footer">
                <div class="av-auth-stack-xs av-w-full">
                  <template x-if="error">
                    <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
                  </template>
                  <div class="av-row-wrap av-drawer-footer-actions">
                    <AvButton variant="ghost" type="button" @click="closeCreateTripDrawer()">Cancel</AvButton>
                    <AvButton type="submit" form="create-trip-form" :disabled="isLoading">
                      <span x-text="isLoading ? 'Saving…' : (editingTripId ? 'Save changes' : 'Save trip')"></span>
                    </AvButton>
                  </div>
                </div>
              </Fragment>
            </AvDrawer>
          </div>
        </template>

        <AvConfirmDialog
          id="delete-group-dialog"
          variant="danger"
          headline="Delete group?"
          description="This will permanently delete this group, its members, trips, and attendance history. This action cannot be undone."
          confirmLabel="Delete group"
          cancelLabel="Cancel"
          @av-confirm="confirmDeleteGroup()"
          @av-cancel="cancelDeleteGroup()"
        />

        <AvConfirmDialog
          id="remove-member-dialog"
          variant="danger"
          headline="Remove member?"
          description="This will permanently delete this member’s group-related attendance and passenger history. If the member has driven trips, removal will be blocked until those trips are reassigned or deleted."
          confirmLabel="Remove member"
          cancelLabel="Cancel"
          @av-confirm="confirmRemoveMember()"
          @av-cancel="cancelRemoveMember()"
        />
      </div>
    </AvContainer>
  </section>
</AppShell>
