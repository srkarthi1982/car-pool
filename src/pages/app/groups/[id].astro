---
import { AvButton, AvCard, AvContainer, AvDrawer, AvEmptyState } from "@ansiversa/components";
import { server } from "../../../actions";
import AppShell from "../../../layouts/AppShell.astro";
import type { CarPoolTrip } from "../../../modules/app/carPoolStore";

export async function getStaticPaths() {
  return [];
}

const { id } = Astro.params;
if (!id) {
  throw new Error("Group ID is required");
}

let groupDetail = null;
let tripHistory: CarPoolTrip[] = [];
let loadError: string | null = null;

try {
  const [detailResult, tripResult] = await Promise.all([
    Astro.callAction(server.loadGroupDetail, { groupId: id }),
    Astro.callAction(server.listTripHistory, { groupId: id }),
  ]);

  groupDetail = detailResult?.data?.group
    ? {
        group: detailResult.data.group,
        members: detailResult.data.members || [],
      }
    : null;
  tripHistory = (tripResult?.data?.trips as any) || [];
} catch (error) {
  console.error("Error loading group workspace:", error);
  loadError = error instanceof Error ? error.message : String(error);
}

const initialState = {
  groupId: id,
  groupDetail,
  tripHistory,
  loadError,
};

const groupName = groupDetail?.group?.name ?? "Group workspace";
---

<AppShell title={`${groupName} – Car Pool`} description="Manage members, trips, and fairness inside the Car Pool workspace.">
  <section class="av-section">
    <AvContainer>
      <div
        class="av-auth-stack-lg"
        x-data="$store.carPoolApp"
        x-init="initializeGroupWorkspace($el.dataset.initial)"
        data-initial={JSON.stringify(initialState)}
      >
        <AvCard className="av-auth-stack-md">
          <div class="av-row-between app-row-top">
            <div class="av-auth-stack-xs">
              <a href="/app" class="av-text-soft app-back-link">← Back to groups</a>
              <p class="av-kicker">Car Pool</p>
              <h1 class="av-section-title">{groupName}</h1>
              <p class="av-text-soft">Overview, members, trips, and fairness stay together in one protected workspace.</p>
            </div>
            <div class="av-row-wrap">
              <AvButton type="button" variant="ghost" @click="openAddMembersDrawer()">Add members</AvButton>
              <AvButton type="button" @click="openCreateTripDrawer()">Log trip</AvButton>
            </div>
          </div>

          <template x-if="error">
            <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
          </template>
        </AvCard>

        <template x-if="selectedGroupDetail.group">
          <div class="av-auth-stack-lg">
            <div class="app-section-grid">
              <AvCard variant="soft" className="av-auth-stack-md">
                <div class="av-auth-stack-xs">
                  <p class="av-kicker">Overview</p>
                  <h2 class="av-card-heading">Rotation snapshot</h2>
                  <p class="av-text-soft">Keep the current driver suggestion and the next few turns visible at a glance.</p>
                </div>

                <div class="app-stat-grid">
                  <div class="app-stat-card">
                    <p class="app-stat-label">Today’s driver</p>
                    <template x-if="getTodaysDriver()">
                      <div class="av-auth-stack-xxs">
                        <p class="app-stat-value" x-text="getTodaysDriver().name"></p>
                        <p class="av-text-soft">Fairness score: <span x-text="getTodaysDriver().fairness?.fairnessScore || 0"></span></p>
                      </div>
                    </template>
                    <template x-if="!getTodaysDriver()">
                      <p class="av-text-soft">No active members yet.</p>
                    </template>
                  </div>

                  <div class="app-stat-card">
                    <p class="app-stat-label">Group status</p>
                    <p class="app-stat-value" x-text="selectedGroupDetail.group.isArchived ? 'Archived' : 'Active'"></p>
                    <p class="av-text-soft">Working days: <span x-text="Array.isArray(selectedGroupDetail.group.workingDays) ? selectedGroupDetail.group.workingDays.length : 0"></span></p>
                  </div>
                </div>

                <div class="av-auth-stack-xs">
                  <p class="app-stat-label">Next drivers</p>
                  <div class="app-list-stack">
                    <template x-for="(driver, index) in getNextDrivers(3)" :key="`${driver.id}-${index}`">
                      <div class="app-list-row">
                        <span class="app-list-title" x-text="driver.name"></span>
                        <span class="av-text-soft" x-text="formatDate(new Date(Date.now() + ((index + 1) * 24 * 60 * 60 * 1000)))"></span>
                      </div>
                    </template>
                  </div>
                </div>
              </AvCard>

              <AvCard variant="soft" className="av-auth-stack-md">
                <div class="av-auth-stack-xs">
                  <p class="av-kicker">Members</p>
                  <h2 class="av-card-heading">Team roster</h2>
                  <p class="av-text-soft">Members appear in the group workspace with their current fairness counts.</p>
                </div>

                <template x-if="selectedGroupDetail.members.length === 0">
                  <AvEmptyState
                    headline="No members yet"
                    description="Add members to start building a real commute rotation."
                  />
                </template>

                <template x-if="selectedGroupDetail.members.length > 0">
                  <div class="app-list-stack">
                    <template x-for="member in selectedGroupDetail.members" :key="member.id">
                      <div class="app-list-row">
                        <div class="av-auth-stack-xxs">
                          <span class="app-list-title" x-text="member.name"></span>
                          <p class="av-text-soft">
                            Drives: <span x-text="member.fairness?.driveCount || 0"></span>
                            · Rides: <span x-text="member.fairness?.rideCount || 0"></span>
                            · Absences: <span x-text="member.fairness?.absenceCount || 0"></span>
                          </p>
                        </div>
                        <span class="app-score-pill" x-text="member.fairness?.fairnessScore || 0"></span>
                      </div>
                    </template>
                  </div>
                </template>
              </AvCard>
            </div>

            <div class="app-section-grid">
              <AvCard variant="soft" className="av-auth-stack-md">
                <div class="av-row-between app-row-top">
                  <div class="av-auth-stack-xs">
                    <p class="av-kicker">Trips</p>
                    <h2 class="av-card-heading">Recent trip log</h2>
                    <p class="av-text-soft">Trip creation stays inside the standard drawer, while history remains anchored in the page.</p>
                  </div>
                  <div class="av-row-wrap">
                    <AvButton type="button" variant="ghost" @click="navigateToTripHistory()">View all trips</AvButton>
                    <AvButton type="button" @click="openCreateTripDrawer()">Log trip</AvButton>
                  </div>
                </div>

                <template x-if="tripHistory.length === 0">
                  <AvEmptyState
                    headline="No trips logged yet"
                    description="Your first trip entry will appear here with driver and attendance details."
                  />
                </template>

                <template x-if="tripHistory.length > 0">
                  <div class="app-list-stack">
                    <template x-for="trip in tripHistory.slice(0, 5)" :key="trip.id">
                      <div class="app-list-row">
                        <div class="av-auth-stack-xxs">
                          <span class="app-list-title" x-text="formatDate(trip.tripDate)"></span>
                          <p class="av-text-soft">
                            Passengers: <span x-text="trip.passengerCount || 0"></span>
                            · Absent: <span x-text="trip.absenteeCount || 0"></span>
                          </p>
                        </div>
                        <AvButton
                          type="button"
                          size="sm"
                          variant="ghost"
                          @click="navigateToTripDetail(trip.id)"
                        >
                          View
                        </AvButton>
                      </div>
                    </template>
                  </div>
                </template>
              </AvCard>

              <AvCard variant="soft" className="av-auth-stack-md">
                <div class="av-auth-stack-xs">
                  <p class="av-kicker">Fairness</p>
                  <h2 class="av-card-heading">Contribution balance</h2>
                  <p class="av-text-soft">Scores stay visible so the group can see who is driving more often than riding.</p>
                </div>

                <template x-if="selectedGroupDetail.members.length === 0">
                  <p class="av-text-soft">Fairness appears once members and trips exist.</p>
                </template>

                <template x-if="selectedGroupDetail.members.length > 0">
                  <div class="app-list-stack">
                    <template x-for="member in selectedGroupDetail.members" :key="member.id">
                      <div class="app-fairness-row">
                        <div class="av-auth-stack-xxs">
                          <span class="app-list-title" x-text="member.name"></span>
                          <p class="av-text-soft">
                            Missed rides: <span x-text="member.fairness?.missedRideCount || 0"></span>
                          </p>
                        </div>
                        <div class="app-fairness-meter">
                          <div
                            class="app-fairness-meter__fill"
                            :style="`width: ${Math.min(100, Math.max(8, 50 + ((member.fairness?.fairnessScore || 0) * 10)))}%`"
                          ></div>
                        </div>
                        <span class="app-score-pill" x-text="member.fairness?.fairnessScore || 0"></span>
                      </div>
                    </template>
                  </div>
                </template>
              </AvCard>
            </div>
          </div>
        </template>

        <template x-if="!selectedGroupDetail.group && !isLoading">
          <AvCard variant="soft">
            <AvEmptyState
              headline="Group unavailable"
              description="This workspace could not be loaded for the current user."
            />
          </AvCard>
        </template>

        <template x-if="showAddMembersDrawer">
          <div
            class="av-drawer-overlay"
            @click.self="closeAddMembersDrawer()"
            @keydown.escape.window="closeAddMembersDrawer()"
            @close-drawer="closeAddMembersDrawer()"
            x-cloak
          >
            <AvDrawer title="Add members" description="Add members into this car pool workspace.">
              <div class="av-auth-stack-md">
                <div class="app-field">
                  <span class="app-label">Quick add member</span>
                  <input
                    type="text"
                    class="app-input"
                    placeholder="Enter member name and press Enter"
                    @keydown.enter.prevent="if ($event.target.value.trim()) { addMemberToForm('user_' + Date.now(), $event.target.value.trim()); $event.target.value = ''; }"
                  />
                </div>

                <div class="av-auth-stack-xs">
                  <p class="av-text-soft">Staged members</p>
                  <template x-if="addMembersForm.members.length === 0">
                    <p class="av-text-soft">No members queued yet.</p>
                  </template>
                  <template x-if="addMembersForm.members.length > 0">
                    <div class="app-list-stack">
                      <template x-for="(member, index) in addMembersForm.members" :key="`${member.userId}-${index}`">
                        <div class="app-list-row">
                          <span class="app-list-title" x-text="member.name"></span>
                          <AvButton type="button" size="sm" variant="ghost" @click="removeMemberFromForm(index)">Remove</AvButton>
                        </div>
                      </template>
                    </div>
                  </template>
                </div>
              </div>

              <Fragment slot="footer">
                <div class="av-auth-stack-xs av-w-full">
                  <template x-if="error">
                    <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
                  </template>
                  <div class="av-row-wrap av-drawer-footer-actions">
                    <AvButton variant="ghost" type="button" @click="closeAddMembersDrawer()">Cancel</AvButton>
                    <AvButton type="button" @click="submitAddMembers()" :disabled="isLoading || addMembersForm.members.length === 0">
                      <span x-text="isLoading ? 'Adding…' : 'Add members'"></span>
                    </AvButton>
                  </div>
                </div>
              </Fragment>
            </AvDrawer>
          </div>
        </template>

        <template x-if="showCreateTripDrawer">
          <div
            class="av-drawer-overlay"
            @click.self="closeCreateTripDrawer()"
            @keydown.escape.window="closeCreateTripDrawer()"
            @close-drawer="closeCreateTripDrawer()"
            x-cloak
          >
            <AvDrawer title="Log trip" description="Record one commute without leaving the group workspace.">
              <form id="create-trip-form" class="av-auth-stack-md" @submit.prevent="submitCreateTrip()">
                <label class="app-field">
                  <span class="app-label">Trip date</span>
                  <input type="date" class="app-input" x-model="createTripForm.tripDate" required />
                </label>

                <label class="app-field">
                  <span class="app-label">Actual driver</span>
                  <select class="app-input" x-model="createTripForm.actualDriverId" required>
                    <option value="">Select driver</option>
                    <template x-for="member in selectedGroupDetail.members" :key="member.id">
                      <option :value="member.id" x-text="member.name"></option>
                    </template>
                  </select>
                </label>

                <div class="app-field">
                  <span class="app-label">Passengers</span>
                  <div class="app-checklist">
                    <template x-for="member in selectedGroupDetail.members" :key="`${member.id}-passenger`">
                      <label class="app-check-item">
                        <input
                          type="checkbox"
                          :value="member.id"
                          x-model="createTripForm.passengers"
                          :disabled="member.id === createTripForm.actualDriverId"
                        />
                        <span x-text="member.name"></span>
                      </label>
                    </template>
                  </div>
                </div>

                <div class="app-field">
                  <span class="app-label">Absentees</span>
                  <div class="app-checklist">
                    <template x-for="member in selectedGroupDetail.members" :key="`${member.id}-absent`">
                      <label class="app-check-item">
                        <input
                          type="checkbox"
                          :value="member.id"
                          x-model="createTripForm.absentees"
                          :disabled="createTripForm.passengers.includes(member.id)"
                        />
                        <span x-text="member.name"></span>
                      </label>
                    </template>
                  </div>
                </div>

                <div class="app-inline-grid">
                  <label class="app-field">
                    <span class="app-label">Petrol amount</span>
                    <input type="number" step="0.01" min="0" class="app-input" x-model="createTripForm.petrolAmount" />
                  </label>
                  <label class="app-field">
                    <span class="app-label">Toll amount</span>
                    <input type="number" step="0.01" min="0" class="app-input" x-model="createTripForm.tollAmount" />
                  </label>
                </div>

                <label class="app-field">
                  <span class="app-label">Notes</span>
                  <textarea class="app-input app-textarea" x-model="createTripForm.notes" rows="3" placeholder="Optional trip notes"></textarea>
                </label>
              </form>

              <Fragment slot="footer">
                <div class="av-auth-stack-xs av-w-full">
                  <template x-if="error">
                    <div class="av-alert av-alert-danger" role="status" x-text="error"></div>
                  </template>
                  <div class="av-row-wrap av-drawer-footer-actions">
                    <AvButton variant="ghost" type="button" @click="closeCreateTripDrawer()">Cancel</AvButton>
                    <AvButton type="submit" form="create-trip-form" :disabled="isLoading">
                      <span x-text="isLoading ? 'Saving…' : 'Save trip'"></span>
                    </AvButton>
                  </div>
                </div>
              </Fragment>
            </AvDrawer>
          </div>
        </template>
      </div>
    </AvContainer>
  </section>
</AppShell>
