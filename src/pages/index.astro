---
import AppShell from "../layouts/AppShell.astro";
import { APP_META } from "../app.meta";
import { buildRootRedirect } from "../lib/redirects";
import LandingPageStandard from "../components/landing/LandingPageStandard.astro";
import { createLandingDemoContent } from "../content/landing-demo";

const rootAppUrl = Astro.locals.rootAppUrl ?? "https://ansiversa.com";
const appUrl = new URL("/app", Astro.url).toString();
const startHref = Astro.locals.isAuthenticated
  ? "/app"
  : buildRootRedirect(rootAppUrl, "/login", appUrl);

const title = `${APP_META.name} | Ansiversa`;
const description = "Private commute fairness system for fixed office groups. Manage driver rotations, attendance, trip logging, and ensure equitable contribution over time.";
const landingContent = createLandingDemoContent({ startHref });
---

<AppShell title={title} description={description}>
  <LandingPageStandard content={landingContent} />
</AppShell>
